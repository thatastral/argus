# Network
NEXT_PUBLIC_MONAD_NETWORK=testnet

# Contract addresses — fill in after `forge script script/Deploy.s.sol` in contracts/
NEXT_PUBLIC_HABIT_MANAGER_ADDRESS=
NEXT_PUBLIC_PENALTY_ENGINE_ADDRESS=
NEXT_PUBLIC_ARGUS_FACTORY_ADDRESS=
# Testnet: MockUSDC address from the deploy script. Mainnet: real USDC's address instead.
NEXT_PUBLIC_USDC_ADDRESS=

# Supabase (Project Settings -> API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Session cookie signing secret — generate with: openssl rand -base64 32
SESSION_SECRET=

# Google AI Studio API key for Gemini 2.5 Flash
GEMINI_API_KEY=

# Backend signer authorized to call HabitManager.completeHabit() after AI verification.
# This account holds no user funds — it only has permission to mark habits complete.
# Must match the address passed as `verifier` to script/Deploy.s.sol.
VERIFIER_PRIVATE_KEY=

# Authorizes the daily settlement cron (see vercel.json + app/api/cron/settle/route.ts).
# Generate with: openssl rand -base64 32. Vercel sends this automatically as
# `Authorization: Bearer $CRON_SECRET` for its own scheduled invocations once this env var is
# set in the project — nothing else to configure on the Vercel side.
CRON_SECRET=
